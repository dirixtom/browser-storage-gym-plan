# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# (.env is gitignored; .env.example is the safe template that is committed.)

# --- GitHub OAuth app (github.com > Settings > Developer settings > OAuth Apps) ---
# Homepage URL:               https://gym.<your-domain>/
# Authorization callback URL: https://gym.<your-domain>/auth/github/callback
GITHUB_CLIENT_ID=your_oauth_client_id
GITHUB_CLIENT_SECRET=your_oauth_client_secret

# Your OWN numeric GitHub user id (NOT your username). Only this account can log in.
# Find it:  curl https://api.github.com/users/<your-login> | grep '"id"'
ALLOWED_GITHUB_ID=12345678

# Long random string used to sign session/state cookies.
# Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# Postgres connection.
# Recommended (no password): local Unix socket + peer auth on the same Mac.
DATABASE_URL=postgres:///gymapp
# Alternative (TCP password): postgres://gymapp:your_db_password@localhost:5432/gymapp

# Public HTTPS origin the app is served from (used to build the OAuth callback URL).
PUBLIC_ORIGIN=https://gym.<your-domain>

# Optional. Server binds to localhost only; the Cloudflare tunnel reaches in.
# PORT=8787
# HOST=127.0.0.1
